node_modules/
dist/
coverage/
playwright-report/
test-results/
.turbo/
*.log
.DS_Store
.claude/
.env
.env.*
!.env.example

# WASM build artifacts
wasm/build/
wasm/*.wasm
# ...except the committed binary the core package ships
!packages/core/src/wasm/coraza.wasm

# NestJS
.nest/

# Next.js build artifacts inside examples
examples/*/.next/
examples/*/next-env.d.ts
examples/*/out/
examples/*/.turbo/

# Playwright artifacts inside packages
packages/*/test-results/
packages/*/playwright-report/

# Editor / OS
*.swp
.idea/
.vscode/
Thumbs.db
# Native `go build` inside wasm/ drops an ELF binary named after the dir.
# Never ship the native build artifact — the deliverable is coraza.wasm.
wasm/wasm

# FTW runner scratch (corpus clone + per-run build artifacts + logs)
testing/ftw/.coreruleset/
testing/ftw/build/

# Matrix runner scratch (per-leg server logs)
testing/matrix/.build/
# Next build artifacts inside matrix cases
testing/matrix/cases/*/.next/
testing/matrix/cases/*/next-env.d.ts
