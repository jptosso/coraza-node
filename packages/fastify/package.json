{
  "name": "@coraza/fastify",
  "version": "0.1.0-preview.2",
  "description": "Fastify plugin for Coraza WAF.",
  "license": "Apache-2.0",
  "author": "Juan Pablo Tosso <jptosso@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/coraza-incubator/coraza-node.git",
    "directory": "packages/fastify"
  },
  "keywords": [
    "fastify",
    "waf",
    "coraza",
    "security",
    "plugin"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup && find dist -name \"*.d.cts\" -delete && find dist -name \"*.d.cts.map\" -delete",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo playwright-report test-results"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "dependencies": {
    "fastify-plugin": "^5.0.1",
    "@coraza/core": "workspace:*"
  },
  "devDependencies": {
    "@coraza/core": "workspace:*",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.5",
    "@vitest/coverage-v8": "^2.1.2",
    "fastify": "^5.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
